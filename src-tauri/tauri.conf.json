{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "鹦鹉剪贴板",
  "version": "../package.json",
  "identifier": "com.robin.clipboard",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "鹦鹉剪贴板",
        "width": 800,
        "height": 384,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/images/**",
          "$APPLOCALDATA/images/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Robin",
    "category": "Productivity",
    "shortDescription": "鹦鹉剪贴板是一款面向 macOS 的剪贴板历史管理工具，支持文本、图片与文件回溯。",
    "longDescription": "鹦鹉剪贴板（Parrot Clipboard）是一个基于 Tauri 的桌面应用，用于管理文本、图片与文件剪贴板历史，提供搜索、预览、回粘、权限引导、更新检查与发布级稳定性能力。",
    "windows": {
      "digestAlgorithm": "sha256",
      "signCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/sign-windows.ps1 %1",
      "wix": {
        "language": "zh-CN"
      }
    },
    "macOS": {
      "bundleName": "鹦鹉剪贴板"
    }
  }
}
